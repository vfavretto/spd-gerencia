generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UsuarioRole {
  ADMINISTRADOR
  ANALISTA
  VISUALIZADOR
}

enum ConvenioStatus {
  RASCUNHO
  EM_ANALISE
  APROVADO
  EM_EXECUCAO
  CONCLUIDO
  CANCELADO
}

enum TipoComunicado {
  ENTRADA
  SAIDA
}

enum TipoEvento {
  REUNIAO
  PRESTACAO_CONTAS
  ENTREGA_DOCUMENTOS
  VENCIMENTO_ETAPA
  OUTROS
}

model Usuario {
  id          Int        @id @default(autoincrement())
  nome        String
  email       String     @unique
  senha       String
  role        UsuarioRole @default(ANALISTA)
  ativo       Boolean    @default(true)
  criadoEm    DateTime   @default(now())
  atualizadoEm DateTime  @updatedAt
  comunicados Comunicado[] @relation("ComunicadosCriados")
}

model Secretaria {
  id          Int        @id @default(autoincrement())
  nome        String     @unique
  sigla       String?    @unique
  responsavel String?
  convenios   Convenio[]
  criadoEm    DateTime   @default(now())
  atualizadoEm DateTime  @updatedAt
}

model OrgaoConcedente {
  id        Int       @id @default(autoincrement())
  nome      String     @unique
  esfera    String?
  contato   String?
  convenios Convenio[]
  criadoEm  DateTime  @default(now())
  atualizadoEm DateTime @updatedAt
}

model Programa {
  id        Int       @id @default(autoincrement())
  nome      String     @unique
  codigo    String?   @unique
  descricao String?
  convenios Convenio[]
  criadoEm  DateTime  @default(now())
  atualizadoEm DateTime @updatedAt
}

model FonteRecurso {
  id        Int       @id @default(autoincrement())
  nome      String     @unique
  tipo      String?
  convenios Convenio[]
  criadoEm  DateTime  @default(now())
  atualizadoEm DateTime @updatedAt
}

model Convenio {
  id                   Int              @id @default(autoincrement())
  codigo               String           @unique
  titulo               String
  objeto               String
  status               ConvenioStatus   @default(RASCUNHO)
  descricao            String?
  observacoes          String?
  valorGlobal          Decimal          @db.Decimal(14, 2)
  valorRepasse         Decimal?         @db.Decimal(14, 2)
  valorContrapartida   Decimal?         @db.Decimal(14, 2)
  dataAssinatura       DateTime?
  dataInicioVigencia   DateTime?
  dataFimVigencia      DateTime?
  dataPrestacaoContas  DateTime?
  secretariaId         Int
  secretaria           Secretaria       @relation(fields: [secretariaId], references: [id])
  orgaoId              Int?
  orgao                OrgaoConcedente? @relation(fields: [orgaoId], references: [id])
  programaId           Int?
  programa             Programa?        @relation(fields: [programaId], references: [id])
  fonteId              Int?
  fonte                FonteRecurso?    @relation(fields: [fonteId], references: [id])
  anexos               ConvenioAnexo[]
  etapas               EtapaConvenio[]
  comunicados          Comunicado[]
  eventos              EventoAgenda[]
  criadoEm             DateTime         @default(now())
  atualizadoEm         DateTime         @updatedAt
}

model ConvenioAnexo {
  id         Int      @id @default(autoincrement())
  nome       String
  url        String
  tipo       String?
  convenioId Int
  convenio   Convenio @relation(fields: [convenioId], references: [id], onDelete: Cascade)
  criadoEm   DateTime @default(now())
}

model EtapaConvenio {
  id             Int      @id @default(autoincrement())
  titulo         String
  descricao      String?
  dataPrevista   DateTime?
  dataRealizada  DateTime?
  responsavel    String?
  situacao       String?  // texto livre (ex: concluído, pendente)
  convenioId     Int
  convenio       Convenio @relation(fields: [convenioId], references: [id], onDelete: Cascade)
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
}

model Comunicado {
  id           Int           @id @default(autoincrement())
  protocolo    String        @unique
  assunto      String
  conteudo     String?
  tipo         TipoComunicado
  status       String?
  dataRegistro DateTime      @default(now())
  origem       String?
  destino      String?
  responsavel  String?
  arquivoUrl   String?
  convenioId   Int?
  convenio     Convenio?     @relation(fields: [convenioId], references: [id])
  criadoPorId  Int?
  criadoPor    Usuario?      @relation("ComunicadosCriados", fields: [criadoPorId], references: [id])
  atualizadoEm DateTime      @updatedAt
}

model EventoAgenda {
  id           Int         @id @default(autoincrement())
  titulo       String
  descricao    String?
  tipo         TipoEvento  @default(OUTROS)
  dataInicio   DateTime
  dataFim      DateTime?
  local        String?
  responsavel  String?
  convenioId   Int?
  convenio     Convenio?   @relation(fields: [convenioId], references: [id])
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt
}
