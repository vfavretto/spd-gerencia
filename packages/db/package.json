{
  "name": "@spd/db",
  "private": true,
  "version": "0.2.0",
  "description": "Camada de persistência compartilhada (Prisma + MySQL)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc --watch --project tsconfig.json",
    "build": "tsc --project tsconfig.json",
    "seed:admin": "ts-node -r dotenv/config --transpile-only scripts/seed_prisma.ts dotenv_config_path=../../.env",
    "seed:convenios": "ts-node -r dotenv/config --transpile-only scripts/seed_convenios.ts dotenv_config_path=../../.env",
    "prisma:generate": "dotenv -e ../../.env -- npx prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- npx prisma migrate dev",
    "prisma:studio": "dotenv -e ../../.env -- npx prisma studio",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "keywords": [
    "prisma",
    "mysql",
    "infra"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.16.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^8.57.1",
    "prisma": "^6.16.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
