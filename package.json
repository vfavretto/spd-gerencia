{
  "name": "spd-prefeitura",
  "private": true,
  "version": "0.2.1",
  "description": "Sistema de gerenciamento interno da Secretaria de Planejamento e Desenvolvimento de Votorantim",
  "scripts": {
    "dev:db": "npm --workspace packages/db run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "dev": "npm-run-all --parallel dev:db dev:api dev:web",
    "build:db": "npm --workspace packages/db run build",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "build": "npm-run-all build:db build:api build:web",
    "lint": "npm --workspaces run lint"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vfavretto/spd-gerencia.git"
  },
  "license": "MIT",
  "keywords": [
    "prefeitura",
    "clean-architecture",
    "monorepo"
  ],
  "author": "Secretaria de Planejamento e Desenvolvimento - Votorantim",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
